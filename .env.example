# Plugin identity
PLUGIN_NAME=wechat
PLUGIN_VERSION=0.1.0
PLUGIN_INSTANCE_ID=wechat-local-001
PLUGIN_PUBLIC_BASE_URL=http://127.0.0.1:8101

# Plugin service
HOST=0.0.0.0
PORT=8101
DEBUG=false
LOG_LEVEL=INFO

# WeChat auth
WECHAT_TOKEN=replace-with-wechat-token
WECHAT_REQUIRE_SIGNATURE=false

# Backend integration
BACKEND_BASE_URL=http://127.0.0.1:8001
BACKEND_MESSAGE_PATH=/wechat/message
BACKEND_REGISTER_PATH=/plugins/register
BACKEND_HEARTBEAT_PATH=/plugins/{instance_id}/heartbeat
BACKEND_TIMEOUT=30

# Optional shared token for backend plugin registry
PLUGIN_REGISTRY_TOKEN=
PLUGIN_AUTO_REGISTER=true
PLUGIN_AUTO_HEARTBEAT=false
PLUGIN_HEARTBEAT_INTERVAL=60

# OpenClaw side registration
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
OPENCLAW_TOKEN=replace-with-openclaw-token
OPENCLAW_TIMEOUT=15
OPENCLAW_CLIENT_ID=gateway-client
OPENCLAW_CLIENT_MODE=backend
OPENCLAW_ROLE=operator
OPENCLAW_AUTO_REGISTER=true
OPENCLAW_APPLY_AFTER_REGISTER=true
OPENCLAW_PLUGIN_ENTRY_KEY=wechat
